{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "auth != null",
        ".write": "auth != null",
        "privateCard": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null"
          }
        },
        "cardDecks": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
